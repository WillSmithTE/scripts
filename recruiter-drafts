#!/bin/bash
# Weekly recruiter email draft creator
# Runs via launchd, invokes Claude Code to search Gmail and create drafts

export PATH="/Users/willy/.nvm/versions/node/v20.19.4/bin:$PATH"

LOGFILE="/tmp/recruiter-drafts.log"
PROMPT_FILE=$(mktemp /tmp/recruiter-prompt.XXXXXX)

echo "$(date): Starting recruiter draft run" >> "$LOGFILE"

GMAIL_DIR="$HOME/.claude/skills/gmail"
GMAIL="$GMAIL_DIR/.venv/bin/python $GMAIL_DIR/scripts/gmail.py"

# Fetch recruiter emails from the past 7 days
RECRUITER_RESULTS=$($GMAIL read --query "is:inbox newer_than:7d (recruiter OR role OR opportunity OR position OR hiring) -category:promotions" --limit 20 --full 2>&1)
LINKEDIN_RESULTS=$($GMAIL read --query "from:linkedin.com newer_than:7d subject:(messaged you OR opportunity OR role OR position)" --limit 10 --full 2>&1)

# Build prompt with email data inlined, instructions use literal $
cat > "$PROMPT_FILE" <<EMAILDATA
You are handling a weekly recruiter email triage for Will Smith (willsmithte@gmail.com).

CONTEXT:
- Will is a SWE at Amazon in Canada
- He is NOT actively looking for roles right now
- He is planning to move to the US in 2027 via E-3 visa (his wife wants to stay in Canada at least another year for their second baby, healthcare system comfort, and support network)
- He wants to maintain good relationships with recruiters for when the time comes
- He has been working with Amy Meyer at Aussie Recruit (amy@aussierecruitsf.com) for US roles specifically

Here are the Gmail search results from the past 7 days:

=== RECRUITER EMAILS ===
$RECRUITER_RESULTS

=== LINKEDIN JOB MESSAGES ===
$LINKEDIN_RESULTS

EMAILDATA

cat >> "$PROMPT_FILE" <<'INSTRUCTIONS'
TASK:
1. Review the emails above. Skip any that are obviously newsletters/bulk. Skip any where Will has already replied.

2. For genuinely personal outreach that needs a reply, create a draft reply using Bash:
   ~/.claude/skills/gmail/.venv/bin/python ~/.claude/skills/gmail/scripts/gmail.py draft --reply-to MSG_ID --body "reply text"

   Drafts MUST sound like Will actually wrote them. His voice is casual, warm, and personal. NOT corporate or polished.

   VOICE RULES:
   - Casual openers: "Hey" or "Hi", never formal
   - Share genuine reactions naturally, like a friend would
   - Use parenthetical asides for personality
   - Show specific enthusiasm about things that matter to him (not generic praise like "compelling" or "solid fit")
   - Sign off casually: "Thanks a lot", "Cheers", not "Best regards"
   - NEVER use words like: "genuinely compelling", "solid fit", "problem space", "I appreciate the persistence", "exploring new roles"
   - Short, conversational. 3-5 sentences max.

   WHAT WILL CARES ABOUT (mention when the role aligns):
   - Working close to the user / customer-focused engineering
   - Full stack / broad skillset, not siloed backend
   - Self-starter environments, working closely with product
   - Interesting real-world problems

   EXAMPLE of Will's actual voice (to Amy about Candid Health):
   "Wow that was quick, sure I'd love to talk with them! I love that they call out that they want customer-focused engineers, that's exactly what I'm looking for, and it looks like it's full stack too which would be ideal."

   EXAMPLE declining (to Amy about timeline):
   "Thanks for checking in. Things are good here, busy like always but lots to do. I've had a slight change in personal circumstances and am actually expecting my first kid towards the end of the year, so I'll be sticking with Amazon for my parental leave in early 2026."

3. After processing, send a push notification via Bash:
   API_KEY=$(grep NOTIFICATIONS_API_KEY ~/.zshrc | tail -1 | sed "s/^export NOTIFICATIONS_API_KEY=//;s/^'//;s/'$//")
   curl -s -X POST https://willsmithte.com/resource/notifications \
     -H 'Content-Type: application/json' \
     -H 'User-Agent: Mozilla/5.0' \
     -H "Authorization: Bearer $API_KEY" \
     --data-binary "$(jq -n --arg title "Recruiter Drafts" --arg body "YOUR SUMMARY HERE" '{title: $title, body: $body}')"

   Include in the summary:
   - How many recruiter emails found
   - How many drafts created
   - Brief description of each draft (who from, what role)
   - If none found: "No recruiter emails to handle this week"

4. If any drafts were created, also email Will a summary so he knows to check his drafts:
   ~/.claude/skills/gmail/.venv/bin/python ~/.claude/skills/gmail/scripts/gmail.py send --to "willsmithte@gmail.com" --subject "Recruiter drafts ready to review" --body "SUMMARY OF DRAFTS"
   Include who each draft is to, what role/company, and a reminder to review and send them from Gmail drafts.
INSTRUCTIONS

claude --print --dangerously-skip-permissions --allowed-tools "Bash" -p "$(cat "$PROMPT_FILE")" >> "$LOGFILE" 2>&1

rm -f "$PROMPT_FILE"
echo "$(date): Finished recruiter draft run" >> "$LOGFILE"
